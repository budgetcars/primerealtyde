# Firebase Web-App (Projekt­einstellungen → Allgemein → Ihre Apps)
# Alle PUBLIC_* Variablen sind im Client sichtbar — hier nur die Web-App-Werte, keine Geheimnisse.

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# Region der Callable Functions (muss mit functions/src/index.ts übereinstimmen, Standard: europe-west1)
PUBLIC_FIREBASE_FUNCTIONS_REGION=europe-west1

# --- Nicht hier ablegen / nicht committen ---
# Dateien wie `*firebase-adminsdk*.json` sind Service-Account-Schlüssel (Admin SDK).
# Sie gehören NICHT in dieses Astro-Frontend und nicht ins Git. Für Cloud Functions,
# Server-Skripte oder CI: als Secret bereitstellen, z. B. GOOGLE_APPLICATION_CREDENTIALS
# auf einen Pfad außerhalb des Repos zeigen.
