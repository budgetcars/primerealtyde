---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { ui } from '../../../i18n/ui';
import { withLocalePath } from '../../../i18n/locale';
import { FirestoreArticleClient } from '../../../components/react/FirestoreArticleClient';

const locale = 'en';
const L = ui[locale];
const slug = Astro.url.searchParams.get('slug');
---

<BaseLayout locale={locale} title={L.textPageTitle} description={L.textPageMeta}>
	<section class="mx-auto max-w-4xl px-4 py-14 md:py-20">
		<FirestoreArticleClient
			client:only="react"
			locale={locale}
			collection="siteTexts"
			slug={slug}
			notFoundMessage={L.textArticleNotFound}
			backHref={withLocalePath('/text', locale)}
			backLabel={L.backToTexts}
		/>
	</section>
</BaseLayout>
