---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AdminApp } from '../../components/react/AdminApp';
import { withLocalePath } from '../../i18n/locale';

const homeHref = withLocalePath('/', 'en');
---

<BaseLayout
	robots="noindex"
	locale="en"
	title="Admin"
	description="Prime Realty — internal listings console (authorised users only)."
	chrome={false}
>
	<div class="mx-auto max-w-7xl px-4 py-12 md:py-16">
		<div class="glass-panel px-6 py-8 md:px-10 md:py-10">
			<h1 class="font-heading-display text-3xl font-semibold tracking-tight text-gray-900 md:text-4xl">Admin</h1>
			<p class="mt-3 max-w-2xl text-slate-600">
				Password‑protected workspace for authorised team members—capture and refresh listing/exposé data on the catalogue.
			</p>
			<p class="mt-4">
				<a href={homeHref} class="text-sm font-semibold text-amber-900 hover:text-amber-950">← Webseite öffnen</a>
			</p>
			<div class="mt-10">
				<AdminApp client:only="react" listingPreviewBase={withLocalePath('/immobilie', 'en')} />
			</div>
		</div>
	</div>
</BaseLayout>
