---
import BaseLayout from '../layouts/BaseLayout.astro';
import { AdminApp } from '../components/react/AdminApp';
import { withLocalePath } from '../i18n/locale';
---

<BaseLayout
	robots="noindex"
	locale="de"
	title="Verwaltung"
	description="Prime Realty – interner Bereich zur Pflege von Immobilien-Exposés (geschützt)."
>
	<div class="mx-auto max-w-7xl px-4 py-12 md:py-16">
		<div class="glass-panel px-6 py-8 md:px-10 md:py-10">
			<h1 class="font-heading-display text-3xl font-semibold tracking-tight text-gray-900 md:text-4xl">
				Verwaltung
			</h1>
			<p class="mt-3 max-w-2xl text-slate-600">
				Geschützter Zugang für autorisierte Mitarbeitende zur Erfassung und Aktualisierung von Objektdaten und Exposés.
			</p>
			<div class="mt-10">
				<AdminApp client:only="react" listingPreviewBase={withLocalePath('/immobilie', 'de')} />
			</div>
		</div>
	</div>
</BaseLayout>
