---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withLocalePath } from '../../i18n/locale';

const homeHref = withLocalePath('/', 'zh');
const privacyHref = withLocalePath('/datenschutz', 'en');
---

<BaseLayout
	locale="zh"
	title="Platform terms"
	description="Terms governing use of the Prime Realty online platform for sellers, partners and visitors."
>
	<div class="mx-auto max-w-3xl px-4 py-12 md:py-16">
		<article class="glass-panel px-8 py-10 md:px-10 md:py-14">
			<h1 class="font-heading-display text-3xl font-semibold tracking-tight text-gray-900 md:text-4xl">Platform terms</h1>
			<p class="mt-4 text-lg font-semibold text-gray-900">Prime Realty</p>

			<div class="mt-14 space-y-14 text-sm leading-relaxed text-slate-700">
				<section>
					<h2 class="text-xl font-bold text-gray-900">1. Acceptance</h2>
					<p class="mt-4">
						These Terms govern all users—including sellers/partners and visitors—of the Prime Realty digital services
						(‘Service’). By using it you agree. If not, discontinue use immediately.
					</p>
					<p class="mt-4">
						They cover offers, texts, visuals and linked policies that may update from time to time.
					</p>
				</section>

				<section>
					<h2 class="text-xl font-bold text-gray-900">2. Changes</h2>
					<p class="mt-4">
						We may amend these Terms; updates take effect upon publication unless mandatory law dictates otherwise—check
						periodically.
					</p>
				</section>

				<section>
					<h2 class="text-xl font-bold text-gray-900">3. Roles</h2>
					<h3 class="mt-8 text-base font-semibold text-gray-900">3.1 Sellers / partners</h3>
					<ul class="mt-4 list-disc space-y-2 pl-5 marker:text-amber-900">
						<li>Keep listing data, pricing and availability accurate and refreshed.</li>
						<li>
							Respond to enquiries, arrange viewings and complete transactions responsibly and in accordance with applicable
							property laws.
						</li>
					</ul>

					<h3 class="mt-8 text-base font-semibold text-gray-900">3.2 Buyers / visitors</h3>
					<ul class="mt-4 list-disc space-y-2 pl-5 marker:text-amber-900">
						<li>Perform independent due diligence ahead of committing.</li>
						<li>Use contact pathways respectfully.</li>
						<li>Listings originate from sellers/partners; we do not systematically verify factual accuracy unless stated.</li>
					</ul>
				</section>

				<section>
					<h2 class="text-xl font-bold text-gray-900">4. Content standards</h2>
					<p class="mt-4">Listings shall meet professional editorial standards adequate for prospective buyers/investors.</p>
					<ul class="mt-4 list-disc space-y-3 pl-5 marker:text-amber-900">
						<li>Legible visuals matching the premises; deceptive renderings discouraged.</li>
						<li>Complete material facts reasonably expected (approx. size/rooms/location/highlights).</li>
						<li>Rights-clear media and copy; licensees grant Prime Realty licence to showcase materials on-platform.</li>
					</ul>
				</section>

				<section>
					<h2 class="text-xl font-bold text-gray-900">5. Data sources shown</h2>
					<ul class="mt-4 list-disc space-y-2 pl-5 marker:text-amber-900">
						<li>Direct submissions authenticated staff upload.</li>
						<li>Partner / CRM integrations.</li>
						<li>Optional curated prominence for selected stock.</li>
					</ul>
					<p class="mt-4">
						Removal requests: <a href="mailto:info@prime-realty.de" class="font-semibold text-amber-900 hover:text-amber-950">info@prime-realty.de</a>.
					</p>
				</section>

				<section>
					<h2 class="text-xl font-bold text-gray-900">6. Privacy & security</h2>
					<p class="mt-4">
						We process personal data in line with GDPR; see our{' '}
						<a href={privacyHref} class="font-semibold text-amber-900 hover:text-amber-950">privacy policy</a>.
					</p>
				</section>

				<section>
					<h2 class="text-xl font-bold text-gray-900">7. Miscellaneous</h2>
					<ul class="mt-4 list-disc space-y-3 pl-5 marker:text-amber-900">
						<li>We may suspend or adjust features maintenance / compliance reasons.</li>
						<li>Accounts may terminate for breaches or legal orders.</li>
						<li>These Terms are governed by German law; exclusive jurisdiction in Stuttgart where legally permissible.</li>
					</ul>
				</section>

				<section>
					<h2 class="text-xl font-bold text-gray-900">8. Contact</h2>
					<p class="mt-4">Questions regarding these Terms:</p>
					<address class="mt-6 not-italic text-slate-700">
						<strong class="text-gray-900">Prime Realty</strong><br />
						Panoramastraße 13<br />
						73765 Neuhausen, Deutschland<br />
						<p class="mt-4">
							E-mail:
							<a href="mailto:info@prime-realty.de" class="font-semibold text-amber-900 hover:text-amber-950">info@prime-realty.de</a>
						</p>
						<p>
							Tel.:
							<a href="tel:+4971125255610" class="font-semibold text-amber-900 hover:text-amber-950">+49&nbsp;711&nbsp;252&nbsp;55&nbsp;610</a>
						</p>
					</address>
				</section>
			</div>

			<p class="mt-14">
				<a href={homeHref} class="text-sm font-semibold text-amber-900 hover:text-amber-950">← Back to home</a>
			</p>
		</article>
	</div>
</BaseLayout>
