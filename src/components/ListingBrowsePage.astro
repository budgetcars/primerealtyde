---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { Locale } from '../i18n/locale';
import { listingsUi } from '../i18n/copy/listingsUi';
import { listingSearchFiltersUi } from '../i18n/copy/listingSearchFilters';
import { ListingsBrowse } from './react/ListingsBrowse';
import { withLocalePath } from '../i18n/locale';
interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const L = listingsUi[locale];
const filt = listingSearchFiltersUi[locale];
const listingsPath = withLocalePath('/immobilien', locale);
const detailPath = withLocalePath('/immobilie', locale);
---

<BaseLayout locale={locale} title={L.pageTitle} description={L.pageMetaDescription}>
	<div class="mx-auto max-w-7xl px-4 py-12 md:py-16">
		<div class="glass-panel px-6 py-8 md:px-10 md:py-10">
			<h1 class="font-heading-display text-3xl font-semibold tracking-tight text-gray-900 md:text-4xl">
				{L.pageTitle}
			</h1>
			<p class="mt-3 max-w-2xl text-slate-600">
				{L.pageLead}
			</p>

			<form id="listing-browse-search" action={listingsPath} method="get" class="mt-8 w-full max-w-4xl">
				<div class="rounded-2xl border border-slate-200/90 bg-white/88 p-3 shadow-md shadow-slate-900/[0.04] backdrop-blur-md sm:p-4">
					<label class="sr-only" for={`browse-q-${locale}`}>{filt.keywordLegend}</label>
					<input
						type="search"
						name="q"
						id={`browse-q-${locale}`}
						value=""
						autocomplete="off"
						placeholder={L.placeholderSearch}
						class="min-h-11 w-full rounded-xl border border-slate-200/90 bg-white/95 px-4 py-2.5 text-sm text-gray-900 shadow-sm backdrop-blur-sm placeholder:text-slate-400 focus:border-amber-300/70 focus:outline-none focus:ring-2 focus:ring-amber-200/35"
					/>
					<div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
					<div class="flex flex-col gap-1.5">
						<label for={`browse-country-${locale}`} class="text-xs font-medium text-slate-600">{filt.countryLegend}</label>
						<select
							name="country"
							id={`browse-country-${locale}`}
							class="min-h-11 rounded-xl border border-slate-200/90 bg-white/90 px-3 py-2 text-sm font-medium text-gray-900 shadow-sm backdrop-blur-sm focus:border-amber-300/70 focus:outline-none focus:ring-2 focus:ring-amber-200/35"
						>
							{
								filt.countries.map(({ slug, label }) => (
									<option value={slug}>{label}</option>
								))
							}
						</select>
					</div>
					<div class="flex flex-col gap-1.5">
						<label for={`browse-type-${locale}`} class="text-xs font-medium text-slate-600">{filt.typeLegend}</label>
						<select
							name="type"
							id={`browse-type-${locale}`}
							class="min-h-11 rounded-xl border border-slate-200/90 bg-white/90 px-3 py-2 text-sm font-medium text-gray-900 shadow-sm backdrop-blur-sm focus:border-amber-300/70 focus:outline-none focus:ring-2 focus:ring-amber-200/35"
						>
							{
								filt.types.map(({ slug, label }) => (
									<option value={slug}>{label}</option>
								))
							}
						</select>
					</div>
					<div class="flex flex-col gap-1.5">
						<label for={`browse-price-${locale}`} class="text-xs font-medium text-slate-600">{filt.priceLegend}</label>
						<select
							name="price_max"
							id={`browse-price-${locale}`}
							class="min-h-11 rounded-xl border border-slate-200/90 bg-white/90 px-3 py-2 text-sm font-medium text-gray-900 shadow-sm backdrop-blur-sm focus:border-amber-300/70 focus:outline-none focus:ring-2 focus:ring-amber-200/35"
						>
							{
								filt.prices.map(({ value, label }) => (
									<option value={value}>{label}</option>
								))
							}
						</select>
					</div>
					<div class="flex flex-col gap-1.5 sm:col-span-2 lg:col-span-1 lg:justify-end">
						<span class="hidden text-xs font-medium text-transparent lg:inline" aria-hidden="true">&nbsp;</span>
						<div class="flex min-h-[2.75rem] flex-wrap gap-2">
							<button
								type="submit"
								class="inline-flex flex-1 min-w-[7rem] items-center justify-center rounded-xl bg-gray-900 px-5 text-sm font-semibold text-white transition hover:bg-gray-800 lg:flex-auto"
							>
								{L.search}
							</button>
							<a
								href={listingsPath}
								class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-700 transition hover:border-amber-300"
							>
								{L.allListings}
							</a>
						</div>
					</div>
					</div>
					<div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
						<div class="flex flex-col gap-1.5">
							<label for={`browse-sort-${locale}`} class="text-xs font-medium text-slate-600">{filt.sortLegend}</label>
							<select
								name="sort"
								id={`browse-sort-${locale}`}
								class="min-h-11 rounded-xl border border-slate-200/90 bg-white/90 px-3 py-2 text-sm font-medium text-gray-900 shadow-sm backdrop-blur-sm focus:border-amber-300/70 focus:outline-none focus:ring-2 focus:ring-amber-200/35"
							>
								{filt.sortOptions.map(({ value, label }) => <option value={value}>{label}</option>)}
							</select>
						</div>
						<div class="flex flex-col gap-1.5">
							<label for={`browse-price-min-${locale}`} class="text-xs font-medium text-slate-600">{filt.priceMinLegend}</label>
							<input
								type="number"
								name="price_min"
								id={`browse-price-min-${locale}`}
								min="0"
								step="1000"
								class="min-h-11 rounded-xl border border-slate-200/90 bg-white/95 px-3 py-2 text-sm text-gray-900 shadow-sm backdrop-blur-sm focus:border-amber-300/70 focus:outline-none focus:ring-2 focus:ring-amber-200/35"
								placeholder="0"
							/>
						</div>
						<div class="flex flex-col gap-1.5">
							<label for={`browse-bedrooms-${locale}`} class="text-xs font-medium text-slate-600">{filt.bedroomsLegend}</label>
							<select
								name="bedrooms_min"
								id={`browse-bedrooms-${locale}`}
								class="min-h-11 rounded-xl border border-slate-200/90 bg-white/90 px-3 py-2 text-sm font-medium text-gray-900 shadow-sm backdrop-blur-sm focus:border-amber-300/70 focus:outline-none focus:ring-2 focus:ring-amber-200/35"
							>
								{filt.bedroomsOptions.map(({ value, label }) => <option value={value}>{label}</option>)}
							</select>
						</div>
						<div class="flex flex-col gap-1.5 sm:col-span-2 xl:col-span-2">
							<label for={`browse-city-${locale}`} class="text-xs font-medium text-slate-600">{filt.cityLegend}</label>
							<input
								type="text"
								name="city"
								id={`browse-city-${locale}`}
								autocomplete="off"
								class="min-h-11 rounded-xl border border-slate-200/90 bg-white/95 px-3 py-2 text-sm text-gray-900 shadow-sm backdrop-blur-sm focus:border-amber-300/70 focus:outline-none focus:ring-2 focus:ring-amber-200/35"
							/>
						</div>
						<label class="flex min-h-11 cursor-pointer items-center gap-2 rounded-xl border border-slate-200/90 bg-white/80 px-3 py-2 text-sm font-medium text-gray-900 shadow-sm backdrop-blur-sm">
							<input type="checkbox" name="featured" value="1" class="h-4 w-4 rounded border-slate-300 text-amber-700" />
							<span>{filt.featuredLegend}</span>
						</label>
					</div>
				</div>
			</form>

			<script is:inline>
				document.addEventListener('DOMContentLoaded', () => {
					const form = document.getElementById('listing-browse-search');
					if (!form || !(form instanceof HTMLFormElement)) return;
					const params = new URLSearchParams(window.location.search);
					const names = /** @type {const} */ ([
						'q',
						'country',
						'type',
						'price_max',
						'price_min',
						'bedrooms_min',
						'city',
						'sort',
					]);
					for (const name of names) {
						const v = params.get(name);
						if (v == null) continue;
						const el = form.elements.namedItem(name);
						if (el instanceof HTMLInputElement) el.value = v;
						else if (el instanceof HTMLSelectElement) {
							const exists = [...el.options].some((opt) => opt.value === v);
							if (exists) el.value = v;
						}
					}
					const feat = form.elements.namedItem('featured');
					if (feat instanceof HTMLInputElement && params.get('featured') === '1') feat.checked = true;
				});
			</script>

			<div class="mt-10">
				<ListingsBrowse client:only="react" locale={locale} listingsListPath={listingsPath} listingDetailBasePath={detailPath} />
			</div>
		</div>
	</div>
</BaseLayout>
