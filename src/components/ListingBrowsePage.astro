---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { Locale } from '../i18n/locale';
import { listingsUi } from '../i18n/copy/listingsUi';
import { ListingsGrid } from './react/ListingsGrid';
import { withLocalePath } from '../i18n/locale';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const u = listingsUi[locale];
const searchQ = Astro.url.searchParams.get('q') ?? '';
const listingsPath = withLocalePath('/immobilien', locale);
const detailPath = withLocalePath('/immobilie', locale);
---

<BaseLayout locale={locale} title={u.pageTitle} description={u.pageMetaDescription}>
	<div class="mx-auto max-w-7xl px-4 py-12 md:py-16">
		<div class="glass-panel px-6 py-8 md:px-10 md:py-10">
			<h1 class="font-heading-display text-3xl font-semibold tracking-tight text-gray-900 md:text-4xl">
				{u.pageTitle}
			</h1>
			<p class="mt-3 max-w-2xl text-slate-600">
				{u.pageLead}
			</p>
			<form action={listingsPath} method="get" class="mt-8 w-full max-w-2xl">
				<label class="sr-only" for={`browse-q-${locale}`}>{u.searchLabel}</label>
				<div
					class="flex flex-col gap-2 rounded-2xl border border-slate-200/90 bg-white/80 p-2 shadow-md shadow-slate-900/[0.04] backdrop-blur-md sm:flex-row sm:items-center sm:gap-0 sm:p-2"
				>
					<input
						type="search"
						name="q"
						id={`browse-q-${locale}`}
						value={searchQ}
						autocomplete="off"
						placeholder={u.placeholderSearch}
						class="min-h-11 min-w-0 flex-1 rounded-xl border border-transparent bg-transparent px-4 py-2 text-sm text-gray-900 placeholder:text-slate-400 focus:border-transparent focus:outline-none focus:ring-0 sm:rounded-full"
					/>
					<div class="flex shrink-0 gap-2 px-1 pb-1 sm:p-0">
						<button
							type="submit"
							class="inline-flex h-11 flex-1 items-center justify-center rounded-xl bg-gray-900 px-6 text-sm font-semibold text-white transition hover:bg-gray-800 sm:flex-none sm:rounded-full"
						>
							{u.search}
						</button>
						{
							searchQ ? (
								<a
									href={listingsPath}
									class="inline-flex h-11 items-center justify-center rounded-xl border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-700 transition hover:border-amber-300 sm:rounded-full"
								>
									{u.allListings}
								</a>
							) : null
						}
					</div>
				</div>
			</form>
			<div class="mt-10">
				<ListingsGrid
					client:only="react"
					initialSearch={searchQ}
					locale={locale}
					listingsListPath={listingsPath}
					listingDetailBasePath={detailPath}
				/>
			</div>
		</div>
	</div>
</BaseLayout>
