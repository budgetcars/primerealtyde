---
import type { Locale } from '../i18n/locale';
import { switchLocaleHref } from '../i18n/locale';
import { ui } from '../i18n/ui';

interface Props {
	locale: Locale;
	pathname: string;
	search?: string;
}

type LangRow = {
	id: Locale;
	flag: string;
	label: string;
	hreflang: string;
};

const { locale, pathname } = Astro.props;
const search = Astro.props.search ?? '';
const L = ui[locale];

/** Eine Flagge sichtbar; alle Sprachen im aufklappbaren Menü */

const langRows: readonly LangRow[] = [
	{ id: 'de', flag: '🇩🇪', label: L.langDeNative, hreflang: 'de' },
	{ id: 'en', flag: '🇬🇧', label: L.langEnNative, hreflang: 'en' },
	{ id: 'ru', flag: '🇷🇺', label: L.langRuNative, hreflang: 'ru-RU' },
	{ id: 'zh', flag: '🇨🇳', label: L.langZhNative, hreflang: 'zh-CN' },
];

const summaryRow = langRows.find((row) => row.id === locale) ?? langRows[0];
---

<div class="prime-lang-switch pointer-events-none fixed bottom-5 left-5 z-[10000] pl-[env(safe-area-inset-left,12px)] pb-[env(safe-area-inset-bottom,12px)]">
	<details
		class="pointer-events-auto relative [&_summary::-webkit-details-marker]:hidden"
		title={L.langAria}
	>
		<summary
			class="flex list-none cursor-pointer items-center rounded-2xl border border-slate-200/90 bg-white/92 p-1.5 shadow-[0_8px_32px_rgba(15,23,42,0.14)] backdrop-blur-xl transition hover:border-amber-200/90"
			aria-label={L.langMenuOpen}
			aria-haspopup="true"
		>
			<span
				class="flex h-11 w-11 select-none items-center justify-center rounded-xl text-[1.65rem] leading-none bg-amber-100/95 ring-2 ring-amber-400/85 ring-offset-2 ring-offset-white"
				title={summaryRow.label}
			>
				<span aria-hidden="true">{summaryRow.flag}</span>
			</span>
			<span class="sr-only">{L.langCurrent}: {summaryRow.label}</span>
		</summary>
		<div
			role="region"
			aria-label={L.langAria}
			class="prime-lang-switch__panel pointer-events-auto absolute bottom-full left-0 z-[10001] mb-2 min-w-[11.5rem] overflow-hidden rounded-2xl border border-slate-200/90 bg-white/95 py-2 shadow-[0_12px_40px_rgba(15,23,42,0.18)] backdrop-blur-xl"
		>
			<ul class="text-sm font-medium">
				{
					langRows.map((row) => {
						const href = switchLocaleHref(pathname, search, row.id);
						const isCur = locale === row.id;
						return (
							<li>
								<a
									href={href}
									hreflang={row.hreflang}
									lang={row.hreflang}
									title={row.label}
									aria-current={isCur ? 'page' : undefined}
									class:list={[
										'flex items-center gap-3 px-3 py-2.5 transition hover:bg-slate-100',
										isCur ? 'bg-amber-50/90 font-semibold text-amber-950' : 'text-gray-900',
									]}
								>
									<span class="inline-flex shrink-0 text-[1.4rem]" aria-hidden="true">
										{row.flag}
									</span>
									<span>{row.label}</span>
								</a>
							</li>
						);
					})
				}
			</ul>
		</div>
	</details>
</div>

<style is:global>
	.prime-lang-switch details:not([open]) .prime-lang-switch__panel {
		display: none;
	}
</style>
