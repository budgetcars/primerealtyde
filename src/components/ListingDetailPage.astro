---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { Locale } from '../i18n/locale';
import { withLocalePath } from '../i18n/locale';
import { ListingDetailClient } from './react/ListingDetailClient';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const listingsListPath = withLocalePath('/immobilien', locale);
---

<BaseLayout locale={locale} title={locale === 'en' ? 'Property' : 'Immobilie'}>
	<div class="mx-auto max-w-7xl px-4 py-12 md:py-16">
		<div class="glass-panel px-6 py-8 md:px-10 md:py-10">
			<ListingDetailClient client:only="react" locale={locale} listingsListPath={listingsListPath} />
		</div>
	</div>
</BaseLayout>
