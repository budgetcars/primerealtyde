---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { Locale } from '../i18n/locale';
import { contactCopy } from '../i18n/copy/contact';
import { listingsUi } from '../i18n/copy/listingsUi';
import { withLocalePath } from '../i18n/locale';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const c = contactCopy[locale];
const nav = listingsUi[locale];

const mailto = 'mailto:info@prime-realty.de';
const tel = 'tel:+4971125255610';
const mapsUrl =
	'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent('Panoramastraße 13, 73765 Neuhausen, Germany');
const homeHref = withLocalePath('/', locale);
const listingsHref = withLocalePath('/immobilien', locale);

const footerNavLabel =
	locale === 'de'
		? 'Seitennavigation'
		: locale === 'en'
			? 'Page navigation'
			: locale === 'ru'
				? 'Навигация по странице'
				: '页面导航';
---

<BaseLayout locale={locale} title={c.title} description={c.metaDescription}>
	<article class="min-h-[55vh] border-b border-slate-200 bg-[#f9fafb]">
		<div class="mx-auto max-w-6xl px-4 pb-20 pt-14 md:pb-28 md:pt-16 lg:pb-32">
			<header class="flex flex-col gap-10 border-b border-slate-200/90 pb-12 md:flex-row md:items-start md:justify-between md:gap-16 md:pb-14 lg:gap-20">
				<div class="min-w-0 max-w-3xl">
					<p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Prime Realty</p>
					<h1
						class="mt-5 font-heading-display text-[2.125rem] font-medium tracking-[-0.02em] text-slate-900 sm:text-[2.5rem] md:text-[2.75rem] md:leading-[1.1]"
					>
						{c.title}
					</h1>
					<p class="mt-6 max-w-2xl text-[1.0625rem] leading-[1.66] text-slate-600">
						{c.intro}
					</p>
				</div>
				<img
					src="/brand/prime-realty-logo.png"
					alt=""
					width={2048}
					height={2048}
					sizes="(min-width: 768px) 14rem, 12rem"
					class="mt-2 max-h-16 w-full max-w-[12rem] shrink-0 self-start object-contain object-left opacity-[0.94] md:mt-9 md:max-h-[5rem] md:max-w-[14rem]"
					loading="eager"
					decoding="async"
				/>
			</header>

			<div class="mt-12 grid gap-16 lg:mt-14 lg:grid-cols-12 lg:gap-x-14 xl:gap-x-20">
				<div class="space-y-16 lg:col-span-5">
					<section>
						<h2 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-500">{c.addressHeading}</h2>
						<address class="mt-5 not-italic">
							<p class="font-heading-display text-lg font-semibold tracking-tight text-slate-900 md:text-xl">Prime Realty</p>
							<p class="mt-4 text-base leading-[1.7] text-slate-700 md:text-[1.0625rem]">
								{c.addressStreet}<br />
								{c.addressCity}<br />
								{c.addressCountry}
							</p>
							<p class="mt-6">
								<a
									href={mapsUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="text-sm font-medium text-slate-900 underline decoration-slate-300 underline-offset-[5px] transition hover:decoration-slate-900"
								>
									{c.mapsOpenLabel}
								</a>
							</p>
						</address>
					</section>

					<section>
						<h2 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-500">{c.hoursHeading}</h2>
						<dl class="mt-5 space-y-0 divide-y divide-slate-200/90 border-y border-slate-200/90 bg-white">
							{
								c.hours.map((row) => (
									<div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 px-0 py-3.5 first:pt-0 last:pb-0">
										<dt class="text-[0.9375rem] font-medium text-slate-900">{row.days}</dt>
										<dd class:list={['text-[0.9375rem] tabular-nums', row.muted ? 'text-slate-500' : 'text-slate-700']}>
											{row.time}
										</dd>
									</div>
								))
							}
						</dl>
						<p class="mt-6 border-l-[3px] border-slate-900 pl-5 text-sm leading-[1.65] text-slate-600 md:text-[0.9375rem]">
							{c.appointmentNote}
						</p>
					</section>
				</div>

				<section class="lg:col-span-7">
					<h2 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-500">{c.reachHeading}</h2>

					<div class="mt-6 border border-slate-200 bg-white shadow-[0_1px_2px_rgba(15,23,42,0.04)]">
						<a
							href={mailto}
							class="group flex flex-col gap-2 border-b border-slate-100 px-5 py-7 transition-colors hover:bg-slate-50/90 sm:flex-row sm:items-end sm:justify-between sm:gap-6 md:px-7 md:py-8"
						>
							<div>
								<p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">{c.emailLabel}</p>
								<p class="mt-3 break-all text-lg font-semibold tracking-tight text-slate-900 md:text-xl">info@prime-realty.de</p>
							</div>
							<span
								class="shrink-0 text-sm font-medium text-slate-900 underline decoration-slate-300 underline-offset-4 decoration-1 transition group-hover:decoration-slate-900"
							>
								{c.mailPrimaryCta}
							</span>
						</a>

						<a
							href={tel}
							class="group flex flex-col gap-2 px-5 py-7 transition-colors hover:bg-slate-50/90 sm:flex-row sm:items-end sm:justify-between sm:gap-6 md:px-7 md:py-8"
						>
							<div>
								<p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">{c.phoneLabel}</p>
								<p class="mt-3 text-lg font-semibold tabular-nums tracking-tight text-slate-900 md:text-xl">+49 (0) 711 252 55 610</p>
							</div>
							<span class="text-sm font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 decoration-1 transition group-hover:text-slate-900 group-hover:decoration-slate-900">
								{c.callPrimaryCta}
							</span>
						</a>
					</div>
				</section>
			</div>

			<nav
				class="mt-16 flex flex-wrap items-center gap-x-7 gap-y-2 border-t border-slate-200/80 pt-10 text-[0.9375rem] md:mt-[4.25rem]"
				aria-label={footerNavLabel}
			>
				<a href={homeHref} class="font-medium text-slate-900 underline decoration-slate-300 underline-offset-4 hover:decoration-slate-900">
					{c.backHome}
				</a>
				<span class="hidden h-4 w-px bg-slate-300 sm:block" aria-hidden="true"></span>
				<a href={listingsHref} class="font-medium text-slate-600 transition hover:text-slate-900">
					{nav.navListings}
				</a>
			</nav>
		</div>
	</article>
</BaseLayout>
