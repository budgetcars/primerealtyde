---
import type { Locale } from '../i18n/locale';
import { stripLocalePrefix, withLocalePath } from '../i18n/locale';
import { ui } from '../i18n/ui';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;

/** Nur Startseite: Header erst nach Scroll einblenden — sonst immer normale Leiste */
const pathname = Astro.url.pathname;
const heroHideHeaderUntilScroll = stripLocalePrefix(pathname) === '/';

const L = ui[locale];

/** In Production-Builds ausgeblendet — Zugang weiterhin direkt unter `/admin`. */
const showAdminNav = import.meta.env.DEV;

const navItems = [
	{ href: withLocalePath('/', locale), label: L.navHome },
	{ href: withLocalePath('/ueber-uns', locale), label: L.navAbout },
	{ href: withLocalePath('/immobilien', locale), label: L.navListings },
	{ href: withLocalePath('/blog', locale), label: L.navBlog },
	{ href: withLocalePath('/partner', locale), label: L.navPartner },
	{ href: withLocalePath('/kontakt', locale), label: L.navContact },
];
---

<header
	id="site-header"
	class="header-root sticky top-0 z-50 overflow-hidden motion-safe:transition-[max-height,opacity,background-color,border-color,box-shadow,backdrop-filter,-webkit-backdrop-filter] motion-safe:duration-300 motion-safe:ease-out"
	data-compact="false"
	data-hero-home={heroHideHeaderUntilScroll ? 'true' : 'false'}
>
	<div class="header-main-row mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 md:gap-6">
		<a
			href={withLocalePath('/', locale)}
			class="group flex min-w-0 flex-1 items-center max-w-[min(100%,36rem)] md:max-w-[44rem]"
			data-compact-flex
			aria-label="Prime Realty Ferienimmobilien"
		>
			<img
				src="/logo-prime.png"
				alt=""
				width={1254}
				height={1254}
				sizes="(min-width: 768px) 44rem, (min-width: 640px) 36rem, 100vw"
				class="header-brand-logo h-[4.5rem] w-full max-h-[5.5rem] object-contain object-left transition-[filter,opacity] group-hover:opacity-92 sm:h-20 md:h-[5.75rem]"
				loading="eager"
				fetchpriority="high"
				decoding="async"
			/>
			<span class="header-brand-wordmark font-heading-display text-xl font-semibold tracking-tight md:text-[1.625rem]"
				>Prime Realty</span
			>
		</a>
		<div class="flex shrink-0 flex-wrap items-center justify-end gap-2 sm:gap-3">
			<nav class="hidden flex-wrap items-center justify-end gap-0.5 sm:flex lg:gap-1">
				{
					navItems.map((item) => (
						<a
							href={item.href}
							class="header-nav-link rounded-xl px-3 py-2 text-sm font-semibold transition-colors transition-[background-color]"
						>
							{item.label}
						</a>
					))
				}
			</nav>
			{
				showAdminNav ? (
					<a
						href={withLocalePath('/admin', locale)}
						class="shrink-0 rounded-xl border border-amber-300/90 bg-gradient-to-br from-white/95 to-amber-50/90 px-3.5 py-2 text-sm font-semibold text-amber-950 shadow-sm backdrop-blur-sm transition hover:border-amber-400 hover:from-white hover:to-amber-100/95"
						aria-label={L.navAdminAria}
					>
						{L.navAdmin}
					</a>
				) : null
			}
		</div>
	</div>
	<!-- Mobile navigation row -->
	<nav class="header-mobile-nav px-2 py-2 sm:hidden">
		<div class="flex max-w-7xl flex-wrap justify-center gap-0.5">
			{
				navItems.map((item) => (
					<a href={item.href} class="header-nav-link rounded-lg px-2.5 py-2 text-xs font-semibold transition-colors transition-[background-color]">
						{item.label}
					</a>
				))
			}
		</div>
	</nav>
</header>

<style>
	/**
	 * Startseite (data-hero-home): oben vollständig eingeklappt — erst nach Scroll sichtbare Glas-Leiste.
	 * Andere URLs: immer sichtbare Leiste mit Glas.
	 */
	#site-header.header-root {
		max-height: none;
		border-bottom-width: 1px;
		border-bottom-style: solid;
	}

	#site-header.header-root[data-compact='true'],
	#site-header.header-root[data-hero-home='false'] {
		background-color: rgb(255 255 255 / 0.34);
		border-bottom-color: rgb(255 255 255 / 0.42);
		-webkit-backdrop-filter: blur(38px) saturate(1.7);
		backdrop-filter: blur(38px) saturate(1.7);
		box-shadow:
			inset 0 1px 0 0 rgb(255 255 255 / 0.55),
			0 4px 28px -10px rgb(0 0 0 / 0.14);
	}

	#site-header.header-root[data-hero-home='true']:not([data-compact='true']) {
		max-height: 0;
		min-height: 0;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		border-bottom-color: transparent;
		background-color: transparent;
		-webkit-backdrop-filter: none;
		backdrop-filter: none;
		box-shadow: none;
	}

	#site-header.header-root[data-hero-home='true'][data-compact='true'] {
		max-height: 11rem;
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
	}

	#site-header:not([data-compact='true']) .header-main-row {
		padding-block: 0.75rem;
	}

	@media (min-width: 768px) {
		#site-header:not([data-compact='true']) .header-main-row {
			padding-block: 1rem;
		}
	}

	#site-header[data-compact='true'] .header-brand-logo,
	#site-header[data-hero-home='false'] .header-brand-logo {
		filter: drop-shadow(0 1px 2px rgb(0 0 0 / 0.12));
	}

	#site-header[data-compact='true'] .header-nav-link,
	#site-header[data-hero-home='false'] .header-nav-link {
		color: rgb(30 41 59);
		text-shadow:
			0 0 12px rgb(255 255 255 / 0.55),
			0 1px 0 rgb(255 255 255 / 0.35);
	}

	#site-header[data-compact='true'] .header-nav-link:hover,
	#site-header[data-hero-home='false'] .header-nav-link:hover {
		color: rgb(15 23 42);
		background-color: rgb(15 23 42 / 0.06);
	}

	#site-header[data-compact='true'] .header-mobile-nav,
	#site-header[data-hero-home='false'] .header-mobile-nav {
		border-top: 1px solid rgb(255 255 255 / 0.38);
		background-color: rgb(255 255 255 / 0.22);
		-webkit-backdrop-filter: blur(28px) saturate(1.6);
		backdrop-filter: blur(28px) saturate(1.6);
	}

	@media (prefers-reduced-transparency: reduce) {
		#site-header[data-compact='true'].header-root,
		#site-header[data-hero-home='false'].header-root {
			-webkit-backdrop-filter: none;
			backdrop-filter: none;
			background-color: rgb(255 255 255 / 0.97);
		}

		#site-header[data-compact='true'] .header-mobile-nav,
		#site-header[data-hero-home='false'] .header-mobile-nav {
			-webkit-backdrop-filter: none;
			backdrop-filter: none;
			background-color: rgb(247 247 247 / 1);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		#site-header.header-root {
			transition: none;
		}
	}

	#site-header .header-brand-wordmark {
		display: none;
		line-height: 1.15;
	}

	#site-header[data-compact='true'] .header-brand-wordmark,
	#site-header[data-hero-home='false'] .header-brand-wordmark {
		color: rgb(15 23 42);
		text-shadow: none;
	}

	#site-header[data-compact='true'] .header-brand-logo {
		height: 2.125rem;
		max-height: 2.35rem;
	}

	@media (min-width: 640px) {
		#site-header[data-compact='true'] .header-brand-logo {
			height: 2.375rem;
			max-height: 2.625rem;
		}
	}

	@media (min-width: 768px) {
		#site-header[data-compact='true'] .header-brand-logo {
			height: 2.625rem;
			max-height: 2.875rem;
		}
	}

	#site-header[data-compact='true'] .header-brand-wordmark {
		display: none;
	}

	#site-header[data-compact='true'] .header-main-row {
		padding-block: 0.35rem;
		gap: 0.45rem;
	}

	@media (min-width: 768px) {
		#site-header[data-compact='true'] .header-main-row {
			padding-block: 0.45rem;
			gap: 0.55rem;
		}
	}

	#site-header[data-compact='true'] a[data-compact-flex] {
		flex: 0 1 auto;
		max-width: 12rem;
	}

	@media (min-width: 640px) {
		#site-header[data-compact='true'] a[data-compact-flex] {
			max-width: 14rem;
		}
	}

	#site-header[data-compact='true'] .header-mobile-nav {
		padding-block: 0.28rem;
	}
</style>

<script is:inline>
	(function () {
		function attach() {
			var el = document.getElementById('site-header');
			if (!el) return;
			var threshold = 72;
			function tick() {
				var y =
					window.scrollY !== undefined ? window.scrollY : document.documentElement.scrollTop || 0;
				el.setAttribute('data-compact', y > threshold ? 'true' : 'false');
			}
			tick();
			window.addEventListener('scroll', tick, { passive: true });
			document.addEventListener('astro:after-swap', tick);
			document.addEventListener('astro:page-load', tick);
		}
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', attach, { once: true });
		} else {
			attach();
		}
	})();
</script>
