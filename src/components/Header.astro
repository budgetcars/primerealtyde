---
import type { Locale } from '../i18n/locale';
import { ui } from '../i18n/ui';
import { withLocalePath } from '../i18n/locale';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const L = ui[locale];

/** In Production-Builds ausgeblendet — Zugang weiterhin direkt unter `/admin`. */
const showAdminNav = import.meta.env.DEV;

const navItems = [
	{ href: withLocalePath('/', locale), label: L.navHome },
	{ href: withLocalePath('/ueber-uns', locale), label: L.navAbout },
	{ href: withLocalePath('/immobilien', locale), label: L.navListings },
	{ href: withLocalePath('/blog', locale), label: L.navBlog },
	{ href: withLocalePath('/text', locale), label: L.navTexts },
	{ href: withLocalePath('/partner', locale), label: L.navPartner },
	{ href: withLocalePath('/kontakt', locale), label: L.navContact },
];
---

<header
	id="site-header"
	class="header-glass sticky top-0 z-50 border-b border-white/15 bg-slate-950/45 shadow-[0_8px_32px_-10px_rgba(0,0,0,0.45)] backdrop-blur-2xl backdrop-saturate-150"
	data-compact="false"
>
	<div class="header-main-row mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3.5 md:gap-6 md:py-5">
		<a
			href={withLocalePath('/', locale)}
			class="group flex min-w-0 flex-1 items-center max-w-[min(100%,36rem)] md:max-w-[44rem]"
			data-compact-flex
			aria-label="Prime Realty Ferienimmobilien"
		>
			<img
				src="/logo-prime.png"
				alt=""
				width={1254}
				height={1254}
				sizes="(min-width: 768px) 44rem, (min-width: 640px) 36rem, 100vw"
				class="header-brand-logo h-[4.5rem] w-full max-h-[5.5rem] object-contain object-left drop-shadow-[0_2px_10px_rgb(0_0_0_/_0.35)] transition-opacity group-hover:opacity-92 sm:h-20 md:h-[5.75rem]"
				loading="eager"
				fetchpriority="high"
				decoding="async"
			/>
			<span class="header-brand-wordmark font-heading-display text-xl font-semibold tracking-tight text-slate-50 md:text-[1.625rem]"
				>Prime Realty</span
			>
		</a>
		<div class="flex shrink-0 flex-wrap items-center justify-end gap-2 sm:gap-3">
			<nav class="hidden flex-wrap items-center justify-end gap-0.5 sm:flex lg:gap-1">
				{
					navItems.map((item) => (
						<a
							href={item.href}
							class="header-nav-link rounded-xl px-3 py-2 text-sm font-medium text-slate-100 transition hover:bg-white/12 hover:text-white"
						>
							{item.label}
						</a>
					))
				}
			</nav>
			{
				showAdminNav ? (
					<a
						href={withLocalePath('/admin', locale)}
						class="shrink-0 rounded-xl border border-amber-300/90 bg-gradient-to-br from-white/95 to-amber-50/90 px-3.5 py-2 text-sm font-semibold text-amber-950 shadow-sm backdrop-blur-sm transition hover:border-amber-400 hover:from-white hover:to-amber-100/95"
						aria-label={L.navAdminAria}
					>
						{L.navAdmin}
					</a>
				) : null
			}
		</div>
	</div>
	<!-- Mobile navigation row -->
	<nav class="header-mobile-nav border-t border-white/10 bg-slate-950/35 px-2 py-2 backdrop-blur-xl sm:hidden">
		<div class="flex max-w-7xl flex-wrap justify-center gap-0.5">
			{
				navItems.map((item) => (
					<a href={item.href} class="header-nav-link rounded-lg px-2.5 py-2 text-xs font-medium text-slate-100 hover:bg-white/12 hover:text-white">
						{item.label}
					</a>
				))
			}
		</div>
	</nav>
</header>

<style>
	.header-glass {
		-webkit-backdrop-filter: blur(24px) saturate(1.2);
	}

	/** Lesbarkeit über wechselndem Bild-inhalt unter dem Frosting */
	#site-header .header-nav-link {
		text-shadow: 0 1px 2px rgb(0 0 0 / 0.5);
	}

	#site-header[data-compact='true'].header-glass {
		background-color: rgb(15 23 42 / 0.58);
	}

	@media (prefers-reduced-transparency: reduce) {
		#site-header.header-glass {
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
			background-color: rgb(15 23 42 / 0.92);
		}
	}

	/** Kompakte Leiste beim Scroll — kleineres Logo, weniger Padding (Wortmarke nur Fallback) */
	#site-header .header-brand-wordmark {
		display: none;
		line-height: 1.15;
	}

	/** Beim Scrollen Logo verkleinern (nicht ausblenden), damit die Marke sichtbar bleibt */
	#site-header[data-compact='true'] .header-brand-logo {
		height: 2.5rem;
		max-height: 2.75rem;
	}

	@media (min-width: 640px) {
		#site-header[data-compact='true'] .header-brand-logo {
			height: 2.75rem;
			max-height: 3rem;
		}
	}

	@media (min-width: 768px) {
		#site-header[data-compact='true'] .header-brand-logo {
			height: 3rem;
			max-height: 3.25rem;
		}
	}

	#site-header[data-compact='true'] .header-brand-wordmark {
		display: none;
	}

	#site-header[data-compact='true'] .header-main-row {
		padding-block: 0.5rem;
		gap: 0.625rem;
	}

	@media (min-width: 768px) {
		#site-header[data-compact='true'] .header-main-row {
			padding-block: 0.625rem;
		}
	}

	#site-header[data-compact='true'] a[data-compact-flex] {
		flex: 0 1 auto;
		max-width: 15rem;
	}

	#site-header[data-compact='true'] .header-mobile-nav {
		padding-block: 0.375rem;
	}
</style>

<script is:inline>
	(function () {
		function attach() {
			var el = document.getElementById('site-header');
			if (!el) return;
			var threshold = 40;
			function tick() {
				var y =
					window.scrollY !== undefined ? window.scrollY : document.documentElement.scrollTop || 0;
				el.setAttribute('data-compact', y > threshold ? 'true' : 'false');
			}
			tick();
			window.addEventListener('scroll', tick, { passive: true });
			document.addEventListener('astro:after-swap', tick);
			document.addEventListener('astro:page-load', tick);
		}
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', attach, { once: true });
		} else {
			attach();
		}
	})();
</script>
