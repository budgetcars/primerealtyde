---
import BaseLayout from '../layouts/BaseLayout.astro';
import { type Locale } from '../i18n/locale';
import { ui } from '../i18n/ui';
import { withLocalePath } from '../i18n/locale';
import { FirestoreArticleClient } from './react/FirestoreArticleClient';

interface Props {
	locale: Locale;
	slug: string;
	title: string;
	description: string;
}

const { locale, slug, title, description } = Astro.props;
const L = ui[locale];
---

<BaseLayout locale={locale} title={title} description={description}>
	<section class="mx-auto max-w-4xl px-4 py-14 md:py-20">
		<FirestoreArticleClient
			client:only="react"
			locale={locale}
			collection="siteTexts"
			slug={slug}
			notFoundMessage={L.textArticleNotFound}
			backHref={withLocalePath('/text', locale)}
			backLabel={L.backToTexts}
		/>
	</section>
</BaseLayout>
