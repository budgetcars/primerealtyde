---
import '../styles/global.css';
import type { Locale } from '../i18n/locale';
import {
	getLocale,
	locales,
	localeHreflang,
	localeHtmlLang,
	localeOg,
	pathHasLocaleMirror,
	stripLocalePrefix,
	withLocalePath,
} from '../i18n/locale';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LanguageFlagSwitch from '../components/LanguageFlagSwitch.astro';

interface Props {
	title: string;
	description?: string;
	locale?: Locale;
}

const pathname = Astro.url.pathname;
const search = Astro.url.search;
const locale: Locale = Astro.props.locale ?? getLocale(pathname);

const defaultMeta: Record<Locale, string> = {
	de:
		'Prime Realty – Premium-Immobilien in Montenegro, Zypern, Nordzypern, Türkei, Georgien, Bali und Thailand.',
	en:
		'Prime Realty – premium real estate in Montenegro, Cyprus, Northern Cyprus, Turkey, Georgia, Bali and Thailand.',
	ru:
		'Prime Realty — премиальная недвижимость в Черногории, на Кипре, в Турции, Грузии, Бали и Таиланде.',
	zh: 'Prime Realty — 聚焦黑山、塞浦路斯、土耳其、格鲁吉亚、巴厘岛与泰国等区域的高端房产。',
};

const { title } = Astro.props;
const description = Astro.props.description ?? defaultMeta[locale];
const fullTitle = title.includes('Prime Realty') ? title : `${title} · Prime Realty`;
const stripped = stripLocalePrefix(pathname);
const canonicalURL =
	Astro.site != null
		? new URL(Astro.url.pathname + search, Astro.site)
		: new URL(Astro.url.href);

const alternateHrefset =
	pathHasLocaleMirror(stripped) && Astro.site != null
		? locales.map((lc) => ({
				lc,
				href: new URL(`${withLocalePath(stripped, lc)}${search}`, Astro.site).href,
				hreflang: localeHreflang(lc),
			}))
		: null;

const alternateXDefaultHref =
	pathHasLocaleMirror(stripped) && Astro.site != null
		? new URL(`${withLocalePath(stripped, 'de')}${search}`, Astro.site).href
		: null;

const ogLocale = localeOg(locale);
---

<!doctype html>
<html lang={localeHtmlLang(locale)}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/brand/prime-realty-logo.jpg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0f2744" />
		<link rel="canonical" href={canonicalURL.href} />
		{
			alternateHrefset && alternateXDefaultHref ? (
				<>
					{alternateHrefset.map(({ href, hreflang }) => (
						<link rel="alternate" hreflang={hreflang} href={href} />
					))}
					<link rel="alternate" hreflang="x-default" href={alternateXDefaultHref} />
				</>
			) : null
		}
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Prime Realty" />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL.href} />
		{
			Astro.site ? (
				<meta
					property="og:image"
					content={`${String(Astro.site).replace(/\/?$/, '')}/brand/prime-realty-logo.jpg`}
				/>
			) : null
		}
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap"
			rel="stylesheet"
		/>
		{
			locale === 'zh' ? (
				<link
					href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700&display=swap"
					rel="stylesheet"
				/>
			) : null
		}
		<title>{fullTitle}</title>
	</head>
	<body
		class="flex min-h-screen flex-col"
		style={locale === 'zh' ? "font-family: Inter, 'Noto Sans SC', system-ui, sans-serif" : undefined}
	>
		<Header locale={locale} />
		<main class="flex-1">
			<slot />
		</main>
		<Footer locale={locale} />
		<LanguageFlagSwitch locale={locale} pathname={pathname} search={search} />
	</body>
</html>
