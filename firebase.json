{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  },
  "hosting": [
    {
      "site": "prime-realty-de",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        {
          "regex": "^/de/?$",
          "destination": "/",
          "type": 301
        },
        {
          "regex": "^/de/(?P<rest>.+)$",
          "destination": "/:rest",
          "type": 301
        },
        {
          "source": "/verwaltung",
          "destination": "/admin",
          "type": 301
        },
        {
          "source": "/en/verwaltung",
          "destination": "/en/admin",
          "type": 301
        },
        {
          "source": "/ru/verwaltung",
          "destination": "/ru/admin",
          "type": 301
        },
        {
          "source": "/zh/verwaltung",
          "destination": "/zh/admin",
          "type": 301
        }
      ],
      "headers": [
        {
          "source": "/assets/**",
          "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }]
        }
      ]
    }
  ]
}
