{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "site": "prime-realty-de",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        {
          "source": "/verwaltung",
          "destination": "/admin",
          "type": 301
        },
        {
          "source": "/en/verwaltung",
          "destination": "/en/admin",
          "type": 301
        },
        {
          "source": "/ru/verwaltung",
          "destination": "/ru/admin",
          "type": 301
        },
        {
          "source": "/zh/verwaltung",
          "destination": "/zh/admin",
          "type": 301
        }
      ],
      "headers": [
        {
          "source": "/assets/**",
          "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }]
        }
      ]
    }
  ]
}
